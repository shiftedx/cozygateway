{
  "name": "cozygateway-contract",
  "version": "0.1.0",
  "description": "Wire contract v1 for cozygateway: TypeBox schemas and TypeScript types for the REST surface, WebSocket frames, and the RichBlock content model.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiftedx/cozygateway.git",
    "directory": "packages/contract"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "lint:package": "publint && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  }
}
